MAX_BOT_TOKEN=your_max_bot_token
ADMIN_PASSWORD=change_me
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_TLS_MODE=default

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

PUBLIC_BASE_URL=https://adminka-max.vercel.app
MAX_WEBHOOK_SECRET=max-secret-12345
CRON_SECRET=max-cron-secret-12345

# Куда бот будет присылать новые заявки из мини-приложения.
# Это может быть chat_id служебной группы MAX “Заявки MAX”.
MAX_NOTIFY_CHAT_ID=

# Для теста вне MAX оставь true. После проверки внутри MAX можно поставить false.
MINIAPP_ALLOW_UNVERIFIED=true
MINIAPP_REQUIRE_FRESH_AUTH=false
MINIAPP_AUTH_MAX_AGE_SECONDS=3600

# Если true, заявка дополнительно попадёт в таблицу max_crm_leads.
CRM_INTEGRATION_ENABLED=false
