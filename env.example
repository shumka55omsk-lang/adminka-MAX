<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Мягкие окна — заявка на замер</title>
  <script src="https://st.max.ru/js/max-web-app.js"></script>
  <style>
    :root {
      --bg: #f6f2ea;
      --bg2: #eff7f6;
      --card: rgba(255,255,255,.88);
      --text: #17201f;
      --muted: #68736f;
      --border: rgba(23,32,31,.12);
      --accent: #0f766e;
      --accent2: #134e4a;
      --warm: #f59e0b;
      --good: #0f766e;
      --bad: #b91c1c;
      --soft: #e8f5f2;
      --radius: 22px;
      --shadow: 0 18px 45px rgba(15, 76, 69, .12);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 82% 0%, rgba(245, 158, 11, .22) 0 150px, transparent 280px),
        radial-gradient(circle at 0% 8%, rgba(15, 118, 110, .22) 0 180px, transparent 330px),
        linear-gradient(180deg, var(--bg2) 0%, var(--bg) 62%, #fff 100%);
      padding: 14px 14px calc(28px + env(safe-area-inset-bottom));
    }

    .app { max-width: 720px; margin: 0 auto; }

    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      padding: 20px;
      min-height: 220px;
      color: #fff;
      background:
        linear-gradient(135deg, rgba(15, 76, 69, .95), rgba(15, 118, 110, .86)),
        url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="900" height="420" viewBox="0 0 900 420"><defs><linearGradient id="g" x1="0" x2="1"><stop offset="0" stop-color="%23ffffff" stop-opacity=".26"/><stop offset="1" stop-color="%23ffffff" stop-opacity=".06"/></linearGradient></defs><path d="M0 80 C180 20 310 90 450 45 C620 -5 730 40 900 10 L900 420 L0 420Z" fill="url(%23g)"/><rect x="70" y="130" width="760" height="210" rx="34" fill="none" stroke="%23ffffff" stroke-opacity=".33" stroke-width="10"/><line x1="322" y1="130" x2="322" y2="340" stroke="%23ffffff" stroke-opacity=".22" stroke-width="8"/><line x1="578" y1="130" x2="578" y2="340" stroke="%23ffffff" stroke-opacity=".22" stroke-width="8"/></svg>');
      background-size: cover;
      box-shadow: var(--shadow);
    }

    .badge {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      padding: 8px 11px;
      border-radius: 999px;
      background: rgba(255,255,255,.16);
      border: 1px solid rgba(255,255,255,.22);
      color: rgba(255,255,255,.92);
      font-size: 13px;
      backdrop-filter: blur(10px);
    }

    h1 {
      margin: 18px 0 10px;
      font-size: 31px;
      line-height: 1.02;
      letter-spacing: -.04em;
      max-width: 520px;
    }

    .subtitle {
      margin: 0;
      color: rgba(255,255,255,.84);
      font-size: 15px;
      line-height: 1.45;
      max-width: 520px;
    }

    .hero-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 18px;
    }
    .hero-metric {
      border: 1px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.12);
      border-radius: 18px;
      padding: 10px;
      backdrop-filter: blur(10px);
    }
    .hero-metric b { display: block; font-size: 15px; }
    .hero-metric span { color: rgba(255,255,255,.76); font-size: 12px; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
      margin: 12px 0;
      backdrop-filter: blur(14px);
    }

    .section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin: 0 0 12px;
      font-size: 18px;
      letter-spacing: -.02em;
    }
    .section-title small { color: var(--muted); font-weight: 600; font-size: 12px; }

    label {
      display: block;
      font-weight: 750;
      font-size: 13px;
      margin: 12px 0 6px;
    }

    input, textarea, select {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 13px 12px;
      font: inherit;
      font-size: 16px;
      background: rgba(255,255,255,.92);
      color: var(--text);
      outline: none;
    }

    input:focus, textarea:focus, select:focus {
      border-color: rgba(15,118,110,.45);
      box-shadow: 0 0 0 4px rgba(15,118,110,.10);
    }
    textarea { min-height: 96px; resize: vertical; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }

    .choice-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .choice {
      border: 1px solid var(--border);
      border-radius: 18px;
      background: rgba(255,255,255,.78);
      padding: 12px 10px;
      cursor: pointer;
      min-height: 88px;
      transition: .18s ease;
    }
    .choice.active {
      border-color: rgba(15,118,110,.55);
      background: #e7f6f2;
      box-shadow: 0 0 0 4px rgba(15,118,110,.09);
    }
    .choice .emoji { font-size: 24px; display: block; margin-bottom: 6px; }
    .choice b { display: block; font-size: 13px; }
    .choice span { display: block; color: var(--muted); font-size: 11px; margin-top: 4px; line-height: 1.25; }

    .pill-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .pill {
      border: 1px solid var(--border);
      background: rgba(255,255,255,.8);
      border-radius: 16px;
      padding: 13px 12px;
      cursor: pointer;
      font-weight: 750;
      text-align: center;
    }
    .pill.active { background: #e7f6f2; border-color: rgba(15,118,110,.55); color: var(--accent2); }

    .window-row {
      display: grid;
      grid-template-columns: 1fr 1fr .72fr 42px;
      gap: 8px;
      align-items: end;
      padding: 10px;
      border: 1px solid var(--border);
      border-radius: 18px;
      background: rgba(255,255,255,.62);
      margin-bottom: 8px;
    }
    .window-row label { margin-top: 0; }
    .remove {
      width: 42px;
      height: 48px;
      border: 0;
      border-radius: 14px;
      color: #991b1b;
      background: #fee2e2;
      font-size: 22px;
      cursor: pointer;
    }

    .summary {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }
    .metric { border-radius: 18px; background: var(--soft); padding: 14px; border: 1px solid rgba(15,118,110,.10); }
    .metric .label { color: var(--muted); font-size: 12px; margin-bottom: 5px; }
    .metric .value { font-size: 23px; font-weight: 900; letter-spacing: -.035em; }
    .breakdown {
      margin-top: 10px;
      border: 1px dashed rgba(15,118,110,.26);
      border-radius: 16px;
      padding: 12px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
      background: rgba(232,245,242,.6);
    }

    .photo-box {
      border: 1px dashed rgba(15,118,110,.40);
      border-radius: 20px;
      padding: 14px;
      background: rgba(232,245,242,.52);
      text-align: center;
    }
    .photo-box input { display: none; }
    .photo-btn {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      padding: 12px 14px;
      border-radius: 999px;
      border: 0;
      background: var(--accent);
      color: #fff;
      font-weight: 850;
      cursor: pointer;
    }
    .photo-note { margin: 9px 0 0; color: var(--muted); font-size: 12px; line-height: 1.35; }
    .preview-wrap { display: none; margin-top: 12px; text-align: left; }
    .preview-wrap.show { display: block; }
    .preview-img { width: 100%; max-height: 260px; object-fit: cover; border-radius: 18px; border: 1px solid var(--border); }
    .preview-meta { color: var(--muted); font-size: 12px; margin: 7px 0 0; }

    .actions {
      position: sticky;
      bottom: 0;
      z-index: 10;
      padding: 12px 0 calc(8px + env(safe-area-inset-bottom));
      background: linear-gradient(180deg, rgba(246,242,234,0), rgba(246,242,234,.92) 30%, var(--bg) 100%);
    }
    button.primary, button.secondary {
      width: 100%;
      border: 0;
      border-radius: 18px;
      padding: 15px 16px;
      font: inherit;
      font-weight: 900;
      font-size: 16px;
      cursor: pointer;
    }
    button.primary { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #fff; box-shadow: 0 12px 22px rgba(15,118,110,.24); }
    button.secondary { background: #fff; color: var(--accent2); border: 1px solid var(--border); margin-top: 8px; }
    button:disabled { opacity: .58; cursor: not-allowed; }

    .status { margin-top: 10px; border-radius: 16px; padding: 12px; font-size: 14px; line-height: 1.35; display: none; }
    .status.show { display: block; }
    .status.good { background: #ecfdf5; color: var(--good); border: 1px solid #a7f3d0; }
    .status.bad { background: #fef2f2; color: var(--bad); border: 1px solid #fecaca; }
    .status.info { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }

    .mini-note { font-size: 12px; color: var(--muted); line-height: 1.35; margin-top: 8px; }
    .link-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
    .link-btn { display: block; text-align: center; text-decoration: none; color: var(--accent2); background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 12px 10px; font-weight: 850; }

    @media (max-width: 560px) {
      body { padding-left: 10px; padding-right: 10px; }
      h1 { font-size: 28px; }
      .hero { padding: 18px; min-height: 230px; }
      .hero-metrics, .choice-grid { grid-template-columns: 1fr; }
      .grid-2, .grid-3, .summary, .pill-row { grid-template-columns: 1fr; }
      .window-row { grid-template-columns: 1fr 1fr; }
      .remove { width: 100%; }
    }
  </style>
</head>
<body>
  <main class="app">
    <section class="hero">
      <div class="badge">🟢 MAX mini app · Мягкие окна Омск</div>
      <h1>Заказать замер мягких окон</h1>
      <p class="subtitle">Выберите объект, добавьте размеры и фото проёма. Мы получим заявку в MAX/CRM и подготовим точный расчёт.</p>
      <div class="hero-metrics">
        <div class="hero-metric"><b>ПВХ 700 мкм</b><span>для беседок и террас</span></div>
        <div class="hero-metric"><b>Замер</b><span>Омск и область</span></div>
        <div class="hero-metric"><b>Монтаж</b><span>скобы, люверсы, молнии</span></div>
      </div>
    </section>

    <section class="card">
      <h2 class="section-title">1. Тип объекта <small>выберите один</small></h2>
      <div class="choice-grid" id="objectChoices">
        <button class="choice active" type="button" data-value="Беседка" data-factor="1"><span class="emoji">🏡</span><b>Беседка</b><span>частный дом / дача</span></button>
        <button class="choice" type="button" data-value="Веранда" data-factor="1"><span class="emoji">🪟</span><b>Веранда</b><span>проёмы и входная зона</span></button>
        <button class="choice" type="button" data-value="Терраса" data-factor="1"><span class="emoji">🌿</span><b>Терраса</b><span>защита от ветра и дождя</span></button>
        <button class="choice" type="button" data-value="Кафе / летник" data-factor="1.12"><span class="emoji">☕</span><b>Кафе</b><span>летник / уличная зона</span></button>
        <button class="choice" type="button" data-value="Навес" data-factor="1"><span class="emoji">⛱️</span><b>Навес</b><span>прямые проёмы</span></button>
        <button class="choice" type="button" data-value="Другое" data-factor="1"><span class="emoji">✏️</span><b>Другое</b><span>уточним по фото</span></button>
      </div>
      <input id="objectType" type="hidden" value="Беседка" />
      <input id="objectFactor" type="hidden" value="1" />
    </section>

    <section class="card">
      <h2 class="section-title">2. Контакты</h2>
      <div class="grid-2">
        <div>
          <label for="name">Имя</label>
          <input id="name" autocomplete="name" placeholder="Как к вам обращаться" />
        </div>
        <div>
          <label for="phone">Телефон</label>
          <input id="phone" autocomplete="tel" inputmode="tel" placeholder="+7 ..." />
        </div>
      </div>
      <button class="secondary" id="requestContactBtn" type="button">Подставить номер из MAX</button>
      <label for="address">Адрес / район</label>
      <input id="address" placeholder="Например: Омск, СНТ..., посёлок" />
      <label for="expectedDate">Когда удобно на замер</label>
      <select id="expectedDate">
        <option>В ближайшие дни</option>
        <option>На этой неделе</option>
        <option>На выходных</option>
        <option>Согласовать по телефону</option>
      </select>
    </section>

    <section class="card">
      <h2 class="section-title">3. Размеры проёмов <small>примерно</small></h2>
      <div id="windows"></div>
      <button class="secondary" id="addWindowBtn" type="button">+ Добавить проём</button>

      <h3 class="section-title" style="margin-top:16px;font-size:16px;">Опции</h3>
      <div class="pill-row" id="mountingChoices">
        <button class="pill active" type="button" data-value="С монтажом" data-install="1">С монтажом</button>
        <button class="pill" type="button" data-value="Только изготовление" data-install="0">Только изготовление</button>
      </div>
      <input id="mountingType" type="hidden" value="С монтажом" />
      <input id="needInstall" type="hidden" value="1" />
      <div class="pill-row" id="zipperChoices" style="margin-top:8px;">
        <button class="pill active" type="button" data-value="Молнии не нужны" data-zippers="0">Без молний</button>
        <button class="pill" type="button" data-value="Нужны молнии" data-zippers="1">Нужны молнии</button>
      </div>
      <input id="needZippers" type="hidden" value="0" />

      <div class="summary">
        <div class="metric">
          <div class="label">Площадь</div>
          <div class="value"><span id="area">0.00</span> м²</div>
        </div>
        <div class="metric">
          <div class="label">Предварительно</div>
          <div class="value"><span id="total">0</span> ₽</div>
        </div>
      </div>
      <div class="breakdown" id="breakdown">Добавьте размеры, чтобы увидеть расчёт.</div>
      <div class="mini-note">Это предварительный расчёт. Точная цена зависит от крепления, окантовки, молний, сложности доступа и замера.</div>
    </section>

    <section class="card">
      <h2 class="section-title">4. Фото замера <small>необязательно</small></h2>
      <div class="photo-box">
        <label class="photo-btn" for="photoInput">📷 Загрузить фото проёма</label>
        <input id="photoInput" type="file" accept="image/*" capture="environment" />
        <p class="photo-note">Фото помогает понять крепёж, уклон крыши и сложность монтажа. Перед отправкой фото будет сжато.</p>
        <div class="preview-wrap" id="previewWrap">
          <img class="preview-img" id="previewImg" alt="Фото проёма" />
          <div class="preview-meta" id="previewMeta"></div>
          <button class="secondary" id="removePhotoBtn" type="button">Удалить фото</button>
        </div>
      </div>
    </section>

    <section class="card">
      <h2 class="section-title">5. Комментарий</h2>
      <textarea id="comment" placeholder="Например: есть уклон крыши, нужна дверь на молнии, крепить к дереву, старые скобы уже стоят"></textarea>
      <div class="link-row">
        <a class="link-btn" href="https://wa.me/79039812452" id="waLink">WhatsApp</a>
        <a class="link-btn" href="https://t.me/Anvar_company" id="tgLink">Telegram</a>
      </div>
    </section>

    <section class="actions">
      <button class="primary" id="submitBtn" type="button">Заказать замер</button>
      <div id="status" class="status"></div>
    </section>
  </main>

  <script>
    const CONFIG = {
      pricePerM2: 1500,
      installPerM2: 500,
      zipperPerOpening: 700,
      minOrder: 5000,
      maxPhotoBytes: 1300 * 1024,
      maxPhotoSide: 1600
    };

    const state = {
      contact: null,
      webApp: window.WebApp || null,
      photoDataUrl: '',
      photoInfo: null
    };

    const $ = (id) => document.getElementById(id);

    function status(text, type = 'info') {
      const el = $('status');
      el.className = `status show ${type}`;
      el.textContent = text;
    }

    function safeOpenLink(url) {
      if (state.webApp && typeof state.webApp.openLink === 'function') {
        state.webApp.openLink(url);
        return;
      }
      window.open(url, '_blank', 'noopener,noreferrer');
    }

    function getInitDataUnsafe() {
      return state.webApp?.initDataUnsafe || {};
    }

    function initMax() {
      try {
        const user = getInitDataUnsafe()?.user;
        if (user?.first_name && !$('name').value) $('name').value = user.first_name;
        if (state.webApp?.ready) state.webApp.ready();
        if (state.webApp?.expand) state.webApp.expand();
        if (state.webApp?.enableClosingConfirmation) state.webApp.enableClosingConfirmation();
      } catch (e) {
        console.warn('MAX Bridge init warning', e);
      }
    }

    function money(value) {
      return Math.round(value || 0).toLocaleString('ru-RU');
    }

    function createWindowRow(data = {}) {
      const row = document.createElement('div');
      row.className = 'window-row';
      row.innerHTML = `
        <div>
          <label>Ширина, см</label>
          <input class="width" inputmode="decimal" type="number" min="1" value="${data.widthCm || ''}" placeholder="250" />
        </div>
        <div>
          <label>Высота, см</label>
          <input class="height" inputmode="decimal" type="number" min="1" value="${data.heightCm || ''}" placeholder="180" />
        </div>
        <div>
          <label>Кол-во</label>
          <input class="count" inputmode="numeric" type="number" min="1" value="${data.count || 1}" />
        </div>
        <button class="remove" type="button" aria-label="Удалить">×</button>
      `;
      row.querySelectorAll('input').forEach((input) => input.addEventListener('input', calculate));
      row.querySelector('.remove').addEventListener('click', () => {
        if (document.querySelectorAll('.window-row').length > 1) row.remove();
        calculate();
      });
      return row;
    }

    function addWindow(data) {
      $('windows').appendChild(createWindowRow(data));
      calculate();
    }

    function getWindows() {
      return Array.from(document.querySelectorAll('.window-row')).map((row) => ({
        widthCm: Number(row.querySelector('.width').value || 0),
        heightCm: Number(row.querySelector('.height').value || 0),
        count: Number(row.querySelector('.count').value || 1)
      })).filter((w) => w.widthCm > 0 && w.heightCm > 0 && w.count > 0);
    }

    function calculate() {
      const windows = getWindows();
      const area = windows.reduce((sum, w) => sum + (w.widthCm / 100) * (w.heightCm / 100) * w.count, 0);
      const openingsCount = windows.reduce((sum, w) => sum + w.count, 0);
      const objectFactor = Number($('objectFactor').value || 1);
      const needInstall = $('needInstall').value === '1';
      const needZippers = $('needZippers').value === '1';
      const base = area * CONFIG.pricePerM2 * objectFactor;
      const install = needInstall ? area * CONFIG.installPerM2 : 0;
      const zippers = needZippers ? openingsCount * CONFIG.zipperPerOpening : 0;
      const subtotal = base + install + zippers;
      const total = area > 0 ? Math.max(CONFIG.minOrder, Math.round(subtotal)) : 0;

      $('area').textContent = area.toFixed(2);
      $('total').textContent = money(total);
      $('breakdown').innerHTML = area > 0
        ? `Плёнка и окантовка: ${money(base)} ₽<br>Монтаж: ${needInstall ? money(install) + ' ₽' : 'не нужен'}<br>Молнии: ${needZippers ? money(zippers) + ' ₽' : 'не нужны'}<br>Минимальный заказ: ${money(CONFIG.minOrder)} ₽`
        : 'Добавьте размеры, чтобы увидеть расчёт.';

      return {
        windows,
        areaM2: Number(area.toFixed(2)),
        openingsCount,
        base: Math.round(base),
        install: Math.round(install),
        zippers: Math.round(zippers),
        total,
        pricePerM2: CONFIG.pricePerM2,
        installPerM2: CONFIG.installPerM2,
        zipperPerOpening: CONFIG.zipperPerOpening,
        objectFactor,
        needInstall,
        needZippers,
        minOrder: CONFIG.minOrder
      };
    }

    async function requestContact() {
      if (!state.webApp || typeof state.webApp.requestContact !== 'function') {
        status('Запрос номера доступен только внутри MAX. Введите телефон вручную.', 'info');
        return;
      }
      try {
        const contact = await state.webApp.requestContact();
        state.contact = contact;
        if (contact?.phone) $('phone').value = contact.phone.startsWith('+') ? contact.phone : `+${contact.phone}`;
        status('Номер подставлен из MAX.', 'good');
      } catch (error) {
        status('Не удалось получить номер из MAX. Введите телефон вручную.', 'bad');
      }
    }

    function readFileAsDataUrl(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ''));
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    function loadImage(src) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = reject;
        img.src = src;
      });
    }

    async function compressPhoto(file) {
      const originalDataUrl = await readFileAsDataUrl(file);
      const img = await loadImage(originalDataUrl);
      const scale = Math.min(1, CONFIG.maxPhotoSide / Math.max(img.width, img.height));
      const width = Math.max(1, Math.round(img.width * scale));
      const height = Math.max(1, Math.round(img.height * scale));
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, width, height);

      let quality = 0.78;
      let dataUrl = canvas.toDataURL('image/jpeg', quality);
      while (dataUrl.length > CONFIG.maxPhotoBytes * 1.37 && quality > 0.46) {
        quality -= 0.08;
        dataUrl = canvas.toDataURL('image/jpeg', quality);
      }
      return {
        dataUrl,
        width,
        height,
        originalName: file.name,
        originalSize: file.size,
        sizeApprox: Math.round(dataUrl.length * 0.75),
        type: 'image/jpeg'
      };
    }

    async function handlePhotoChange(event) {
      const file = event.target.files && event.target.files[0];
      if (!file) return;
      if (!/^image\//.test(file.type)) {
        status('Можно загрузить только изображение.', 'bad');
        return;
      }
      status('Сжимаем фото...', 'info');
      try {
        const result = await compressPhoto(file);
        state.photoDataUrl = result.dataUrl;
        state.photoInfo = result;
        $('previewImg').src = result.dataUrl;
        $('previewMeta').textContent = `${result.originalName || 'Фото'} · ${result.width}×${result.height} · примерно ${Math.round(result.sizeApprox / 1024)} КБ`;
        $('previewWrap').classList.add('show');
        status('Фото добавлено к заявке.', 'good');
      } catch (error) {
        status(`Не удалось обработать фото: ${error.message}`, 'bad');
      }
    }

    function removePhoto() {
      state.photoDataUrl = '';
      state.photoInfo = null;
      $('photoInput').value = '';
      $('previewImg').src = '';
      $('previewWrap').classList.remove('show');
      status('Фото удалено.', 'info');
    }

    async function submitLead() {
      const estimate = calculate();
      const form = {
        name: $('name').value.trim(),
        phone: $('phone').value.trim(),
        address: $('address').value.trim(),
        objectType: $('objectType').value,
        mountingType: $('mountingType').value,
        needZippers: $('needZippers').value === '1',
        expectedDate: $('expectedDate').value,
        comment: $('comment').value.trim(),
        windows: estimate.windows
      };

      if (!form.name && !form.phone) {
        status('Укажите имя или телефон.', 'bad');
        return;
      }
      if (!estimate.windows.length) {
        status('Добавьте хотя бы один размер проёма.', 'bad');
        return;
      }

      $('submitBtn').disabled = true;
      status('Отправляем заявку...', 'info');

      try {
        const response = await fetch('/api/miniapp-submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: 'max-miniapp-soft-windows-v16',
            initData: state.webApp?.initData || '',
            initDataUnsafe: getInitDataUnsafe(),
            contact: state.contact,
            form,
            estimate,
            photoDataUrl: state.photoDataUrl,
            photoInfo: state.photoInfo
          })
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.ok) {
          throw new Error(data.error || `Ошибка ${response.status}`);
        }
        status('Заявка отправлена. Мы свяжемся с вами и согласуем замер.', 'good');
        if (state.webApp?.disableClosingConfirmation) state.webApp.disableClosingConfirmation();
      } catch (error) {
        status(`Ошибка отправки: ${error.message}`, 'bad');
      } finally {
        $('submitBtn').disabled = false;
      }
    }

    document.querySelectorAll('#objectChoices .choice').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#objectChoices .choice').forEach((x) => x.classList.remove('active'));
        btn.classList.add('active');
        $('objectType').value = btn.dataset.value;
        $('objectFactor').value = btn.dataset.factor || '1';
        calculate();
      });
    });

    document.querySelectorAll('#mountingChoices .pill').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#mountingChoices .pill').forEach((x) => x.classList.remove('active'));
        btn.classList.add('active');
        $('mountingType').value = btn.dataset.value;
        $('needInstall').value = btn.dataset.install;
        calculate();
      });
    });

    document.querySelectorAll('#zipperChoices .pill').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#zipperChoices .pill').forEach((x) => x.classList.remove('active'));
        btn.classList.add('active');
        $('needZippers').value = btn.dataset.zippers;
        calculate();
      });
    });

    $('addWindowBtn').addEventListener('click', () => addWindow());
    $('requestContactBtn').addEventListener('click', requestContact);
    $('submitBtn').addEventListener('click', submitLead);
    $('photoInput').addEventListener('change', handlePhotoChange);
    $('removePhotoBtn').addEventListener('click', removePhoto);
    $('waLink').addEventListener('click', (e) => { e.preventDefault(); safeOpenLink(e.currentTarget.href); });
    $('tgLink').addEventListener('click', (e) => { e.preventDefault(); safeOpenLink(e.currentTarget.href); });

    addWindow({ widthCm: 250, heightCm: 180, count: 1 });
    initMax();
  </script>
</body>
</html>
